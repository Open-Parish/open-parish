{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "WebWorker"],
    "strict": true,
    "skipLibCheck": true,
    "types": ["./worker-configuration.d.ts"],
    "jsx": "react-jsx",
    "allowJs": false,
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": ["src/index.ts", "src/cf/**/*.ts"]
}
