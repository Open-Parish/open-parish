FROM node:22-bookworm-slim AS build

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

FROM node:22-bookworm-slim AS runtime

WORKDIR /app

COPY package*.json ./
RUN npm ci --omit=dev && npm i -g wrangler@4

COPY --from=build /app/dist ./dist
COPY --from=build /app/migrations ./migrations
COPY --from=build /app/seeds ./seeds
COPY --from=build /app/wrangler.toml ./wrangler.toml

EXPOSE 8787

CMD ["npx", "wrangler", "dev", "dist/index.js", "--local", "--ip", "0.0.0.0", "--port", "8787"]
