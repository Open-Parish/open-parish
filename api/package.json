{
  "name": "olshp-api-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "d1:migrate:local": "wrangler d1 migrations apply olshp --local",
    "d1:migrate:remote": "wrangler d1 migrations apply olshp --remote",
    "d1:seed:local": "wrangler d1 execute olshp --local --file ./migrations/0002_seed.sql"
  },
  "dependencies": {
    "hono": "^4.7.2",
    "mongodb": "^7.1.0"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "wrangler": "^4.4.0"
  }
}
