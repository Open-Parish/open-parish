{
  "name": "openparish-api-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "docker:build": "docker build -t openparish/open-parish-api:latest -f Dockerfile.dev .",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "d1:migrate:local": "wrangler d1 migrations apply openparish --local",
    "d1:migrate:remote": "wrangler d1 migrations apply openparish --remote",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run format"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "file-type": "^21.3.2",
    "hono": "^4.7.2",
    "jose": "^6.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.8.2",
    "wrangler": "^4.4.0"
  }
}
